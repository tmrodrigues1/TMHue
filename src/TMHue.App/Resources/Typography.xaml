<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Somente fontes garantidas em qualquer Windows 10/11 (inclusive LTSC). "Segoe UI
         Variable" e "Cascadia Mono" não existem em edições enxutas; a busca de fallback do
         DirectWrite por uma família ausente pode estourar UnauthorizedAccessException em
         máquinas com cache de fontes com permissões quebradas, derrubando o primeiro Measure
         da MainWindow (visto em campo no LTSC). -->
    <FontFamily x:Key="Font.Display">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Text">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas, Courier New</FontFamily>

    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

    <Style x:Key="Text.HexValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

    <Style x:Key="Text.RgbValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Text}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Text}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextTertiary}" />
    </Style>

</ResourceDictionary>
