    <!-- Contraste (WCAG) -->
    <sys:String x:Key="L.Contrast.WindowTitle">Contraste (WCAG) — TMHue</sys:String>
    <sys:String x:Key="L.Contrast.Title">Contraste (WCAG)</sys:String>
    <sys:String x:Key="L.Contrast.Tip1a">WCAG</sys:String>
    <sys:String x:Key="L.Contrast.Tip1b"> (Web Content Accessibility Guidelines) são as diretrizes internacionais de acessibilidade web, mantidas pelo W3C. Elas existem para garantir que pessoas com baixa visão ou daltonismo consigam ler o conteúdo.</sys:String>
    <sys:String x:Key="L.Contrast.Tip2a">Contraste WCAG</sys:String>
    <sys:String x:Key="L.Contrast.Tip2b"> mede o quão fácil é ler um texto sobre um fundo, com base nessas diretrizes.</sys:String>
    <sys:String x:Key="L.Contrast.Tip3a">Informe a cor do texto e a do fundo em HEX, RGB ou HSL (ou use o conta-gotas). </sys:String>
    <sys:String x:Key="L.Contrast.Tip3b">AA</sys:String>
    <sys:String x:Key="L.Contrast.Tip3c"> é o mínimo recomendado; </sys:String>
    <sys:String x:Key="L.Contrast.Tip3d">AAA</sys:String>
    <sys:String x:Key="L.Contrast.Tip3e"> é o nível reforçado. Texto grande (18pt+ ou 14pt+ em negrito) exige menos contraste.</sys:String>
    <sys:String x:Key="L.Contrast.Tip4a">Para alterar o formato de cor padrão, acesse </sys:String>
    <sys:String x:Key="L.Contrast.TextColor">Cor do texto</sys:String>
    <sys:String x:Key="L.Contrast.BackgroundColor">Cor do fundo</sys:String>
    <sys:String x:Key="L.Contrast.PickTextTip">Capturar cor do texto com o conta-gotas</sys:String>
    <sys:String x:Key="L.Contrast.PickBackgroundTip">Capturar cor do fundo com o conta-gotas</sys:String>
