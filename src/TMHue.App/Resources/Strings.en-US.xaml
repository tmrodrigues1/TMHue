    <sys:String x:Key="L.Settings.Theme">Theme</sys:String>
    <sys:String x:Key="L.Settings.ThemeTip1a">System</sys:String>
    <sys:String x:Key="L.Settings.ThemeTip1b"> automatically follows the light/dark mode configured in Windows.</sys:String>
