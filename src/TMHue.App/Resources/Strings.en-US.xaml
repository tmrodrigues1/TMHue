    <!-- Contrast (WCAG) -->
    <sys:String x:Key="L.Contrast.WindowTitle">Contrast (WCAG) — TMHue</sys:String>
    <sys:String x:Key="L.Contrast.Title">Contrast (WCAG)</sys:String>
    <sys:String x:Key="L.Contrast.Tip1a">WCAG</sys:String>
    <sys:String x:Key="L.Contrast.Tip1b"> (Web Content Accessibility Guidelines) are the international web accessibility guidelines maintained by the W3C. They exist to make sure people with low vision or color blindness can read the content.</sys:String>
    <sys:String x:Key="L.Contrast.Tip2a">WCAG contrast</sys:String>
    <sys:String x:Key="L.Contrast.Tip2b"> measures how easy it is to read text over a background, based on those guidelines.</sys:String>
    <sys:String x:Key="L.Contrast.Tip3a">Enter the text and background colors in HEX, RGB or HSL (or use the eyedropper). </sys:String>
    <sys:String x:Key="L.Contrast.Tip3b">AA</sys:String>
    <sys:String x:Key="L.Contrast.Tip3c"> is the recommended minimum; </sys:String>
    <sys:String x:Key="L.Contrast.Tip3d">AAA</sys:String>
    <sys:String x:Key="L.Contrast.Tip3e"> is the enhanced level. Large text (18pt+ or bold 14pt+) requires less contrast.</sys:String>
    <sys:String x:Key="L.Contrast.Tip4a">To change the default color format, open </sys:String>
    <sys:String x:Key="L.Contrast.TextColor">Text color</sys:String>
