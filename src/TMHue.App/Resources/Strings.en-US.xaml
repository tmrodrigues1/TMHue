    <sys:String x:Key="L.Settings.Language">Language</sys:String>
    <sys:String x:Key="L.Settings.LanguageTip">The change is applied immediately to all windows.</sys:String>
    <sys:String x:Key="L.Settings.SampleTitle">Color sampling</sys:String>
    <sys:String x:Key="L.Settings.SampleTip1a">Exact pixel</sys:String>
    <sys:String x:Key="L.Settings.SampleTip1b"> reads the exact color of the pixel under the cursor — ideal for hitting a precise point, like an icon's edge.</sys:String>
    <sys:String x:Key="L.Settings.SampleTip2a">5×5 average (recommended) / 11×11</sys:String>
    <sys:String x:Key="L.Settings.SampleTip2b"> compute the dominant color of a small area around the cursor, avoiding variations caused by compression noise, anti-aliasing or gradients — ideal for sampling a surface's color.</sys:String>
    <sys:String x:Key="L.Settings.SampleTip3">Applied automatically in real time as you hover — no need to restart the capture.</sys:String>
    <sys:String x:Key="L.Settings.CopyFormatTitle">Copy format</sys:String>
    <sys:String x:Key="L.Settings.CopyTip0">Default format when capturing a color:</sys:String>
    <sys:String x:Key="L.Settings.CopyTip1a">1 HEX</sys:String>
    <sys:String x:Key="L.Settings.CopyTip1b"> — #RRGGBB, the standard for the web and design tools.</sys:String>
    <sys:String x:Key="L.Settings.CopyTip2a">2 RGB</sys:String>
    <sys:String x:Key="L.Settings.CopyTip2b"> — rgb(r, g, b), the three channels in decimal.</sys:String>
    <sys:String x:Key="L.Settings.CopyTip3a">3 HSL</sys:String>
