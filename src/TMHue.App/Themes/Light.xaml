<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SurfaceElevated" Color="#FFF7F7F9" />
    <SolidColorBrush x:Key="Brush.SurfaceSunken" Color="#FFEFEFF3" />
    <SolidColorBrush x:Key="Brush.Border" Color="#1A000000" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#33000000" />

    <!-- WCAG: on the white/near-white surfaces, TextPrimary ≈ 15.9:1, TextSecondary ≈ 5.7:1 and
         TextTertiary ≈ 4.8:1 — all above the 4.5:1 AA minimum for normal text. The old alphas
         (8A/54) flattened to ≈3.9:1 and ≈2.3:1 and failed AA. -->
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF16161A" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#A616161A" />
    <SolidColorBrush x:Key="Brush.TextTertiary" Color="#9916161A" />

    <SolidColorBrush x:Key="Brush.Accent" Color="#FF2F6FED" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF2760D0" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF1F52B8" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#182F6FED" />
    <SolidColorBrush x:Key="Brush.HotkeyText" Color="#FF6A4BE0" />

    <!-- Tool buttons on light: flat near-white fill (#FDFDFD) with a #EEEEF2 outline, and dark
         text (white text would vanish on this fill). Hover/pressed nudge the fill darker. -->
    <SolidColorBrush x:Key="Brush.CaptureGradient" Color="#FFFDFDFD" />
    <SolidColorBrush x:Key="Brush.CaptureGradientHover" Color="#FFF2F2F5" />
    <SolidColorBrush x:Key="Brush.CaptureGradientPressed" Color="#FFE9E9EE" />
    <SolidColorBrush x:Key="Brush.CaptureButtonText" Color="#FF16161A" />
    <SolidColorBrush x:Key="Brush.CaptureButtonBorder" Color="#FFEEEEF2" />

    <!-- Feedback colors, AA-compliant on the light surfaces (error ≈ 5.6:1, success ≈ 5.0:1). -->
    <SolidColorBrush x:Key="Brush.Error" Color="#FFC42B2B" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF1B7F4D" />

    <SolidColorBrush x:Key="Brush.OverlayScrim" Color="#59000000" />
    <SolidColorBrush x:Key="Brush.PreviewSurface" Color="#F5222226" />
    <SolidColorBrush x:Key="Brush.PreviewText" Color="#FFF5F5F7" />

    <DropShadowEffect x:Key="Shadow.Window" Color="#000000" Opacity="0.18" BlurRadius="28" ShadowDepth="6" Direction="270" />
    <DropShadowEffect x:Key="Shadow.Card" Color="#000000" Opacity="0.10" BlurRadius="14" ShadowDepth="3" Direction="270" />
    <DropShadowEffect x:Key="Shadow.Preview" Color="#000000" Opacity="0.35" BlurRadius="22" ShadowDepth="8" Direction="270" />

</ResourceDictionary>
