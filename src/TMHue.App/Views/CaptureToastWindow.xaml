<Window x:Class="TMHue.App.Views.CaptureToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display">
    <!-- The outer margin gives the drop shadow room to render instead of being clipped,
         which is also what kept the old pill's edge looking jagged. -->
    <Grid Margin="24">
        <Border Background="#F514131A"
                BorderBrush="#2EFFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="20" ShadowDepth="4" Direction="270" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="SwatchDot" Width="24" Height="24" CornerRadius="8"
                        Background="#5B8DF6" BorderBrush="#40FFFFFF" BorderThickness="1"
                        Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock x:Name="HexText" Text="#000000" FontFamily="Consolas, Courier New"
                           FontSize="13" FontWeight="SemiBold" Foreground="#FFF5F4F8" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource L.Toast.Copied}" FontFamily="Segoe UI" FontSize="13"
                           Foreground="#FF8A8894" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
