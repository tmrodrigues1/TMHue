<Window x:Class="TMHue.App.Views.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.UpdateProgress.WindowTitle}"
        Width="340"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{DynamicResource Shadow.Window}"
            Margin="14">

        <StackPanel Margin="24,20">
            <StackPanel Orientation="Horizontal">
                <Border Background="{DynamicResource Brush.SurfaceSunken}"
                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                        CornerRadius="9" Width="28" Height="28">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Brush.HotkeyText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="TitleText" Text="{DynamicResource L.UpdateProgress.Title}" Style="{StaticResource Text.Title}"
                           FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="{DynamicResource L.UpdateProgress.Downloading}"
                       Style="{StaticResource Text.Body}" Margin="0,14,0,0" />

            <!-- Rounded, theme-colored determinate bar; the percentage is mirrored as text so
                 progress is readable even at a glance. -->
            <Border Background="{DynamicResource Brush.SurfaceSunken}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="7" Height="14" Margin="0,12,0,0" ClipToBounds="True">
                <Grid x:Name="ProgressTrack">
                    <Border x:Name="ProgressFill" Background="{DynamicResource Brush.CaptureGradient}"
                            CornerRadius="6" HorizontalAlignment="Left" Width="0" />
                </Grid>
            </Border>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource L.UpdateProgress.Source}"
                           Style="{StaticResource Text.Caption}" FontSize="10" VerticalAlignment="Center" />
                <TextBlock x:Name="PercentText" Grid.Column="1" Text="0%"
                           FontFamily="{StaticResource Font.Mono}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.HotkeyText}" />
            </Grid>

            <TextBlock Text="{DynamicResource L.UpdateProgress.RestartNote}"
                       Style="{StaticResource Text.Caption}" FontSize="11" Margin="0,10,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
