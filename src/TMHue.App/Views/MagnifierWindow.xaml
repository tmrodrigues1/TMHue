<Window x:Class="TMHue.App.Views.MagnifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight">
    <Border Background="#FF1B1B22" BorderBrush="#FF3A3A44" BorderThickness="1" CornerRadius="10" Padding="8">
        <StackPanel>
            <TextBlock Text="Aperte ESC para cancelar" Foreground="#FF9A99A6" FontFamily="Segoe UI"
                       FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,0" />
            <TextBlock Text="Use Shift+Setas para mover o cursor" Foreground="#FF9A99A6" FontFamily="Segoe UI"
                       FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <Grid Width="132" Height="132">
                <Border ClipToBounds="True" CornerRadius="4">
                    <!-- NearestNeighbor keeps each source pixel as a crisp 12x12 block instead of
                         a blurred bilinear smear, which is the whole point of the lens. -->
                    <Image x:Name="PixelImage" Width="132" Height="132"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           SnapsToDevicePixels="True" />
                </Border>
                <!-- Center-cell crosshair: 132 / 11 = 12px per cell, so a 12x12 centered border
                     lines up exactly with the middle cell without any extra bookkeeping. -->
                <Border Width="12" Height="12" BorderBrush="White" BorderThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
            </Grid>
            <TextBlock x:Name="HexLabel" Text="#000000" Foreground="White" FontFamily="Consolas"
                       FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock x:Name="FormatHint" FontFamily="Segoe UI" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>
    </Border>
</Window>
