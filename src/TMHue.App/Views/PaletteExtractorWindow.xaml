<Window x:Class="TMHue.App.Views.PaletteExtractorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TMHue.App.Converters"
        Title="{DynamicResource L.Palette.WindowTitle}"
        Width="400"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AllowDrop="True"
        Drop="OnDrop"
        DragOver="OnDragOver">

    <Window.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Border Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{DynamicResource Shadow.Window}"
            Margin="14">

        <Grid Margin="22,10,22,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar, same proportions as the other modals. -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarDrag" Background="Transparent" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Grid instead of a horizontal StackPanel: a StackPanel measures at infinite
                     width and overflows its star column, drawing the subtitle underneath the
                     help icon; the Grid's star column keeps the text confined and trimmed. -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Brush.SurfaceSunken}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                            CornerRadius="9" Width="28" Height="28">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.HotkeyText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="{DynamicResource L.Palette.Title}" Style="{StaticResource Text.Title}" FontSize="15" />
                        <TextBlock Text="{DynamicResource L.Palette.Subtitle}" Style="{StaticResource Text.Caption}"
                                   FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>

                <!-- Discreet help icon: explains the feature without cluttering the layout. -->
                <TextBlock Grid.Column="1" Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                           Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"
                           Margin="0,0,10,0" Cursor="Help"
                           ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="60000">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <StackPanel MaxWidth="250">
                                <TextBlock TextWrapping="Wrap" LineHeight="17">
                                    <Run Text="{DynamicResource L.Palette.Tip1a}" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text="{DynamicResource L.Palette.Tip1b}" />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                    <Run Text="{DynamicResource L.Palette.Tip2a}" /><Run Text="{DynamicResource L.Palette.Tip2b}"
                                         FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text="{DynamicResource L.Palette.Tip2c}" />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                    <Run Text="{DynamicResource L.Palette.Tip3a}" /><Run Text="{DynamicResource L.Palette.Tip3b}"
                                         FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text="{DynamicResource L.Palette.Tip3c}" />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                    <Run Text="{DynamicResource L.Palette.Tip4a}" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text="{DynamicResource L.Palette.Tip4b}" />
                                </TextBlock>
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>

                <Button Grid.Column="2" Style="{StaticResource Button.Close}" Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Width="30" Height="30"
                        Click="OnCloseClick" ToolTip="{DynamicResource L.Common.Close}" />
            </Grid>

            <!-- Drop zone / preview card -->
            <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1"
                    CornerRadius="14" Margin="0,12,0,0" Height="150" ClipToBounds="True">
                <Grid>
                    <!-- Placeholder shown until an image is loaded. -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE7C5;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                   Foreground="{DynamicResource Brush.TextTertiary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource L.Palette.DropHere}" Style="{StaticResource Text.Body}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                        <TextBlock Text="PNG · JPG · BMP · GIF · WEBP" Style="{StaticResource Text.Caption}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>

                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
            </Border>

            <!-- Actions: capture a screen region; once an image is loaded, a clear button appears
                 beside it so the user can start over (drop another image also works anytime). -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource Button.Capture}" FontSize="13" Height="44"
                        Click="OnCaptureRegionClick" HorizontalAlignment="Stretch"
                        ToolTip="{DynamicResource L.Palette.CaptureRegionTip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7A8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource Brush.CaptureButtonText}" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource L.Palette.CaptureRegion}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Style="{StaticResource Button.SettingsPill}" Height="44"
                        Margin="8,0,0,0" Padding="14,0" Click="OnClearImageClick"
                        Visibility="{Binding HasImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{DynamicResource L.Palette.ClearImageTip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource L.Palette.ClearImage}" VerticalAlignment="Center" Margin="7,0,0,0" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Extracted palette card -->
            <Border Grid.Row="3" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="14,10" Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Palette.Extracted}" Style="{StaticResource Text.Title}" FontSize="13" Margin="0,0,0,6" />

                    <TextBlock Text="{DynamicResource L.Palette.EmptyHint}"
                               FontSize="11" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Five columns, rows added as needed: 15 colors render as three rows of 5. -->
                    <ItemsControl ItemsSource="{Binding Palette}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,8,8">
                                    <Border Style="{StaticResource Swatch.History}" Width="Auto" Height="38"
                                            CornerRadius="8" Background="{Binding Brush}"
                                            ToolTip="{Binding CopyTooltip}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.CopySwatchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                    </Border>
                                    <TextBlock Text="{Binding Value}" FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9" Foreground="{DynamicResource Brush.TextSecondary}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Brush.Error}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
