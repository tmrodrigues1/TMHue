<Window x:Class="TMHue.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TMHue.App.Converters"
        Title="{DynamicResource L.Settings.WindowTitle}"
        Width="400"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Border Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{DynamicResource Shadow.Window}"
            Margin="14">

        <Grid Margin="22,10,22,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar, matching the main window's proportions exactly. -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarDrag" Background="Transparent" Height="42">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource Brush.SurfaceSunken}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                            CornerRadius="9" Width="28" Height="28">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.HotkeyText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{DynamicResource L.Common.Settings}" Style="{StaticResource Text.Title}" FontSize="15"
                               Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource Button.Close}" Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Width="30" Height="30"
                        Click="OnCloseClick" ToolTip="{DynamicResource L.Common.Close}" />
            </Grid>

            <!-- Preferences card: tighter vertical rhythm so the whole window fits shorter screens. -->
            <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="16,12" Margin="0,8,0,0">
                <StackPanel>
                    <CheckBox Content="{DynamicResource L.Settings.StartWithWindows}" IsChecked="{Binding StartWithWindows}" Margin="0,0,0,10" />
                    <CheckBox Content="{DynamicResource L.Settings.CloseToTray}" IsChecked="{Binding CloseToTray}" Margin="0,0,0,10" />
                    <CheckBox Content="{DynamicResource L.Settings.ShowCaptureNotification}" IsChecked="{Binding ShowCaptureNotification}" Margin="0,0,0,10" />
                    <CheckBox Content="{DynamicResource L.Settings.ShowMagnifier}" IsChecked="{Binding ShowMagnifier}" />
                </StackPanel>
            </Border>

            <!-- Appearance card: theme and language side by side, same layout as the capture card. -->
            <Border Grid.Row="2" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="16,12" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource L.Settings.Theme}" Style="{StaticResource Text.Title}" FontSize="13" />
                            <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"
                                       Margin="6,0,0,0" Cursor="Help"
                                       ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="60000">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="250">
                                            <TextBlock TextWrapping="Wrap" LineHeight="17">
                                                <Run Text="{DynamicResource L.Settings.ThemeTip2a}" FontWeight="SemiBold"
                                                     Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                                     Text="{DynamicResource L.Settings.ThemeTip2b}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                        <ComboBox SelectedIndex="{Binding SelectedThemeIndex}">
                            <ComboBoxItem Content="{DynamicResource L.Settings.ThemeLight}" />
                            <ComboBoxItem Content="{DynamicResource L.Settings.ThemeDark}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource L.Settings.Language}" Style="{StaticResource Text.Title}" FontSize="13" />
                            <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"
                                       Margin="6,0,0,0" Cursor="Help"
                                       ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="60000">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="{DynamicResource L.Settings.LanguageTip}" TextWrapping="Wrap"
                                                   LineHeight="17" MaxWidth="250" />
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedIndex="{Binding SelectedLanguageIndex}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Capture options card: sample area and copy format share one card, side by side,
                 instead of two stacked cards — the single biggest height saving in this window. -->
            <Border Grid.Row="3" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="16,12" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource L.Settings.SampleTitle}" Style="{StaticResource Text.Title}" FontSize="13" />
                        <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"
                                   Margin="6,0,0,0" Cursor="Help"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="60000">
                            <TextBlock.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="250">
                                        <TextBlock TextWrapping="Wrap" LineHeight="17">
                                            <Run Text="{DynamicResource L.Settings.SampleTip1a}" FontWeight="SemiBold"
                                                 Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                                 Text="{DynamicResource L.Settings.SampleTip1b}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                            <Run Text="{DynamicResource L.Settings.SampleTip2a}" FontWeight="SemiBold"
                                                 Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                                 Text="{DynamicResource L.Settings.SampleTip2b}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                            <Run Text="{DynamicResource L.Settings.SampleTip3}" />
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                    <ComboBox SelectedIndex="{Binding SelectedSampleAreaIndex}">
                        <ComboBoxItem Content="{DynamicResource L.Settings.SampleExact}" />
                        <ComboBoxItem Content="{DynamicResource L.Settings.Sample5}" />
                        <ComboBoxItem Content="{DynamicResource L.Settings.Sample11}" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource L.Settings.CopyFormatTitle}" Style="{StaticResource Text.Title}" FontSize="13" />
                        <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"
                                   Margin="6,0,0,0" Cursor="Help"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="60000">
                            <TextBlock.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="260">
                                        <TextBlock TextWrapping="Wrap" LineHeight="17">
                                            <Run Text="{DynamicResource L.Settings.CopyTip0}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                            <Run Text="{DynamicResource L.Settings.CopyTip1a}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                                 Text="{DynamicResource L.Settings.CopyTip1b}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,6,0,0">
                                            <Run Text="{DynamicResource L.Settings.CopyTip2a}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                                 Text="{DynamicResource L.Settings.CopyTip2b}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,6,0,0">
                                            <Run Text="{DynamicResource L.Settings.CopyTip3a}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                                 Text="{DynamicResource L.Settings.CopyTip3b}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                            <Run Text="{DynamicResource L.Settings.CopyTip4}" />
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding CopyFormatOptions}" SelectedIndex="{Binding SelectedCopyFormatIndex}" />
                </StackPanel>
                </Grid>
            </Border>

            <!-- Hotkeys card: one compact line per hotkey (name · combo · Alterar) instead of the
                 old two-line rows, so five hotkeys take barely more height than three did. -->
            <Border Grid.Row="4" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="16,12" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Settings.Hotkeys}" Style="{StaticResource Text.Title}" FontSize="13" Margin="0,0,0,10" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource L.Main.HotkeyCopy}" Style="{StaticResource Text.Body}"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding CaptureHotkeyDisplay, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.HotkeyText}" Margin="0,0,10,0" />
                        <Button Grid.Column="2" Content="{DynamicResource L.Common.Change}" Tag="capture" Style="{StaticResource Button.Pill}"
                                Padding="10,4" VerticalAlignment="Center" Click="OnChangeHotkeyClick" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource L.Main.HotkeyOpenApp}" Style="{StaticResource Text.Body}"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding OpenAppHotkeyDisplay, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.HotkeyText}" Margin="0,0,10,0" />
                        <Button Grid.Column="2" Content="{DynamicResource L.Common.Change}" Tag="open-app" Style="{StaticResource Button.Pill}"
                                Padding="10,4" VerticalAlignment="Center" Click="OnChangeHotkeyClick" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource L.Main.HotkeyContrast}" Style="{StaticResource Text.Body}"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding ContrastCheckerHotkeyDisplay, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.HotkeyText}" Margin="0,0,10,0" />
                        <Button Grid.Column="2" Content="{DynamicResource L.Common.Change}" Tag="open-contrast-checker" Style="{StaticResource Button.Pill}"
                                Padding="10,4" VerticalAlignment="Center" Click="OnChangeHotkeyClick" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource L.Main.HotkeyHarmony}" Style="{StaticResource Text.Body}"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding HarmonyHotkeyDisplay, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.HotkeyText}" Margin="0,0,10,0" />
                        <Button Grid.Column="2" Content="{DynamicResource L.Common.Change}" Tag="open-harmony" Style="{StaticResource Button.Pill}"
                                Padding="10,4" VerticalAlignment="Center" Click="OnChangeHotkeyClick" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource L.Main.HotkeyPalette}" Style="{StaticResource Text.Body}"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding PaletteExtractorHotkeyDisplay, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.HotkeyText}" Margin="0,0,10,0" />
                        <Button Grid.Column="2" Content="{DynamicResource L.Common.Change}" Tag="open-palette-extractor" Style="{StaticResource Button.Pill}"
                                Padding="10,4" VerticalAlignment="Center" Click="OnChangeHotkeyClick" />
                    </Grid>

                    <TextBlock Text="{Binding HotkeyError}" Foreground="{DynamicResource Brush.Error}" FontSize="12"
                               Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding HotkeyError, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- Updates card -->
            <Border Grid.Row="5" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="16,12" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Text.Body}" VerticalAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,12,0"
                               Foreground="{DynamicResource Brush.TextPrimary}">
                        <Run Text="{DynamicResource L.Settings.Updates}" /><LineBreak /><Run
                             Text="{Binding UpdateStatus, Mode=OneWay}"
                             Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="{DynamicResource L.Settings.Check}" Style="{StaticResource Button.Pill}"
                                Click="OnCheckForUpdatesClick" IsEnabled="{Binding CanCheckForUpdates}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
