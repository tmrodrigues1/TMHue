<Window x:Class="TMHue.App.Views.ContrastCheckerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TMHue.App.Converters"
        Title="Contraste (WCAG) — TMHue"
        Width="400"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:PassFailToTextConverter x:Key="PassFailToText" />
        <conv:PassFailToBrushConverter x:Key="PassFailToBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
        <conv:StringToHiddenVisibilityConverter x:Key="StringToHiddenVisibility" />

        <!-- Local hex-input style: same rounded/sunken language as the rest of the app, scoped to
             this window since no shared TextBox style exists yet. -->
        <Style x:Key="Input.Hex" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSunken}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{DynamicResource Shadow.Window}"
            Margin="14">

        <Grid Margin="22,10,22,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar, matching the main window's proportions exactly. -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarDrag" Background="Transparent" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource Brush.SurfaceSunken}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                            CornerRadius="9" Width="28" Height="28">
                        <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.HotkeyText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Contraste (WCAG)" Style="{StaticResource Text.Title}" FontSize="15" />
                        <!-- Discreet reminder of the color format currently set as default. -->
                        <TextBlock Text="{Binding DefaultFormatLabel}" Style="{StaticResource Text.Caption}"
                                   FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <!-- Discreet help icon: explains the feature without cluttering the layout. -->
                <TextBlock Grid.Column="1" Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                           Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"
                           Margin="0,0,10,0" Cursor="Help"
                           ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="60000">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <StackPanel MaxWidth="250">
                                <TextBlock TextWrapping="Wrap" LineHeight="17">
                                    <Run Text="WCAG" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text=" (Web Content Accessibility Guidelines) são as diretrizes internacionais de acessibilidade web, mantidas pelo W3C. Elas existem para garantir que pessoas com baixa visão ou daltonismo consigam ler o conteúdo." />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                    <Run Text="Contraste WCAG" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text=" mede o quão fácil é ler um texto sobre um fundo, com base nessas diretrizes." />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                    <Run Text="Informe a cor do texto e a do fundo em HEX, RGB ou HSL (ou use o conta-gotas). " /><Run
                                         Text="AA" FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text=" é o mínimo recomendado; " /><Run
                                         Text="AAA" FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" /><Run
                                         Text=" é o nível reforçado. Texto grande (18pt+ ou 14pt+ em negrito) exige menos contraste." />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="17" Margin="0,8,0,0">
                                    <Run Text="Para alterar o formato de cor padrão, acesse " /><Run
                                         Text="Configurações" FontWeight="SemiBold" Foreground="{DynamicResource Brush.HotkeyText}" />.
                                </TextBlock>
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>

                <Button Grid.Column="2" Style="{StaticResource Button.Close}" Content="&#xE713;"
                        FontFamily="Segoe MDL2 Assets" FontSize="12" Width="30" Height="30"
                        Margin="0,0,6,0" Click="OnSettingsClick" ToolTip="Configurações" />

                <Button Grid.Column="3" Style="{StaticResource Button.Close}" Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Width="30" Height="30"
                        Click="OnCloseClick" ToolTip="Fechar" />
            </Grid>

            <!-- Color inputs card -->
            <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="14,10" Margin="0,12,0,0">
                <StackPanel>
                    <!-- Text and background color inputs stack vertically and span the full card
                         width, so longer values (rgb(…), hsl(…)) always have room instead of being
                         clipped in a half-width column. Rows are kept tight (small swatch, small
                         gaps) so the extra row doesn't grow the window beyond the main app's size. -->
                    <StackPanel>
                        <TextBlock Text="Cor do texto" Style="{StaticResource Text.Caption}" FontSize="11"
                                   Foreground="White" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="7"
                                    BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1"
                                    Background="{Binding TextBrush}" Margin="0,0,6,0" Cursor="Hand"
                                    ToolTip="Capturar cor do texto com o conta-gotas">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding PickTextColorCommand}" />
                                </Border.InputBindings>
                            </Border>
                            <TextBox Grid.Column="1" Style="{StaticResource Input.Hex}" MaxLength="{Binding MaxColorInputLength}"
                                     PreviewTextInput="OnHexPreviewTextInput"
                                     DataObject.Pasting="OnHexPasting"
                                     Text="{Binding TextHex, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Text="Cor do fundo" Style="{StaticResource Text.Caption}" FontSize="11"
                                   Foreground="White" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="7"
                                    BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1"
                                    Background="{Binding BackgroundBrush}" Margin="0,0,6,0" Cursor="Hand"
                                    ToolTip="Capturar cor do fundo com o conta-gotas">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding PickBackgroundColorCommand}" />
                                </Border.InputBindings>
                            </Border>
                            <TextBox Grid.Column="1" Style="{StaticResource Input.Hex}" MaxLength="{Binding MaxColorInputLength}"
                                     PreviewTextInput="OnHexPreviewTextInput"
                                     DataObject.Pasting="OnHexPasting"
                                     Text="{Binding BackgroundHex, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- Preview + ratio card -->
            <Border Grid.Row="2" CornerRadius="14" Padding="10,6" Margin="0,14,0,0"
                    Background="{Binding BackgroundBrush}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Aa" FontFamily="{StaticResource Font.Display}" FontSize="17" FontWeight="SemiBold"
                               Foreground="{Binding TextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding RatioText}" FontFamily="{StaticResource Font.Mono}" FontSize="13"
                               FontWeight="SemiBold" Foreground="{Binding TextBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <!-- Results card -->
            <Border Grid.Row="3" Background="{DynamicResource Brush.SurfaceElevated}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    CornerRadius="14" Padding="16,8" Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="Resultado WCAG" Style="{StaticResource Text.Title}" FontSize="13" Margin="0,0,0,6" />

                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Texto normal — AA" Style="{StaticResource Text.Body}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding PassesAaNormalText, Converter={StaticResource PassFailToText}}"
                                   Foreground="{Binding PassesAaNormalText, Converter={StaticResource PassFailToBrush}}"
                                   FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Texto normal — AAA" Style="{StaticResource Text.Body}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding PassesAaaNormalText, Converter={StaticResource PassFailToText}}"
                                   Foreground="{Binding PassesAaaNormalText, Converter={StaticResource PassFailToBrush}}"
                                   FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Texto grande — AA" Style="{StaticResource Text.Body}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding PassesAaLargeText, Converter={StaticResource PassFailToText}}"
                                   Foreground="{Binding PassesAaLargeText, Converter={StaticResource PassFailToBrush}}"
                                   FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Texto grande — AAA" Style="{StaticResource Text.Body}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding PassesAaaLargeText, Converter={StaticResource PassFailToText}}"
                                   Foreground="{Binding PassesAaaLargeText, Converter={StaticResource PassFailToBrush}}"
                                   FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Always reserves the same space (MinHeight) whether or not a suggestion is
                         currently shown, so the window's height never changes. -->
                    <StackPanel Margin="0,10,0,0" MinHeight="30"
                                Visibility="{Binding SuggestionText, Converter={StaticResource StringToHiddenVisibility}}">
                        <TextBlock Text="Recomendação:" FontFamily="{StaticResource Font.Text}" FontSize="11"
                                   FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="{Binding SuggestionText}" Style="{StaticResource Text.Caption}" FontSize="11"
                                   Foreground="White" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
