<Window x:Class="TMHue.App.Views.RegionCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#33000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Canvas x:Name="SelectionCanvas">
        <!-- Rubber-band selection rectangle: accent border + faint fill, drawn while dragging. -->
        <Border x:Name="SelectionRect"
                BorderBrush="{DynamicResource Brush.Accent}"
                BorderThickness="2"
                CornerRadius="4"
                Background="#22FFFFFF"
                Visibility="Collapsed" />

        <!-- Instruction pill, centered at the top of the primary work area. -->
        <Border x:Name="HintPill"
                Background="{DynamicResource Brush.SurfaceElevated}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1"
                CornerRadius="12" Padding="16,9">
            <TextBlock Text="{DynamicResource L.Region.Hint}"
                       FontFamily="{StaticResource Font.Text}" FontSize="13"
                       Foreground="{DynamicResource Brush.TextPrimary}" />
        </Border>
    </Canvas>
</Window>
